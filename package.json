{
  "name": "bountarr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "pwsh -NoLogo -NoProfile -File .\\helpers\\helper-server-start.ps1",
    "preview": "vite preview",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:ui": "playwright test",
    "test:integration": "pwsh -NoLogo -NoProfile -File .\\helpers\\helper-test-integration.ps1",
    "reset:db": "pwsh -NoLogo -NoProfile -File .\\helpers\\helper-data-reset-acquisition-db.ps1",
    "smoke": "pwsh -NoLogo -NoProfile -File .\\helpers\\helper-smoke-ui.ps1",
    "validate": "npm run format:check && npm run lint && npm run check && npm run test && npm run build"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "svelte": "^5.55.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.5.0",
    "@unocss/svelte-scoped": "^66.6.7",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "unocss": "^66.6.7",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
